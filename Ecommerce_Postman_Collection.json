{
  "info": {
    "name": "E-Commerce API Complete",
    "description": "Full collection containing every endpoint for the SEF E-commerce API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register (Send OTP)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"testuser@gmail.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {"raw": "{{base_url}}/auth/register/send-otp", "host": ["{{base_url}}"], "path": ["auth", "register", "send-otp"]}
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@gmail.com\",\n  \"otp\": \"123456\"\n}"
            },
            "url": {"raw": "{{base_url}}/auth/verify-otp", "host": ["{{base_url}}"], "path": ["auth", "verify-otp"]}
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if(res.accessToken) { pm.collectionVariables.set('token', res.accessToken); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@gmail.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {"raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"]}
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/auth/logout", "host": ["{{base_url}}"], "path": ["auth", "logout"]}
          }
        },
        {
          "name": "Forgot Password (Send Link)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@gmail.com\"\n}"
            },
            "url": {"raw": "{{base_url}}/auth/forgot-password/send-otp", "host": ["{{base_url}}"], "path": ["auth", "forgot-password", "send-otp"]}
          }
        },
        {
          "name": "Forgot Password (Reset)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"otp\": \"TOKEN_HERE\",\n  \"newPassword\": \"NewPassword123!\"\n}"
            },
            "url": {"raw": "{{base_url}}/auth/forgot-password/verify-otp", "host": ["{{base_url}}"], "path": ["auth", "forgot-password", "verify-otp"]}
          }
        },
        {
          "name": "Get Me (Profile)",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"]}
          }
        }
      ]
    },
    {
      "name": "2. Users",
      "item": [
        {
          "name": "Add User (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newuser\",\n  \"email\": \"newuser@gmail.com\",\n  \"password\": \"Pass123!\",\n  \"role\": \"customer\"\n}"
            },
            "url": {"raw": "{{base_url}}/users/add", "host": ["{{base_url}}"], "path": ["users", "add"]}
          }
        },
        {
          "name": "Get All Users (Admin)",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/users/all", "host": ["{{base_url}}"], "path": ["users", "all"]}
          }
        },
        {
          "name": "Get User (Admin)",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/users/USER_ID_HERE", "host": ["{{base_url}}"], "path": ["users", "USER_ID_HERE"]}
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"UpdatedName\"\n}"
            },
            "url": {"raw": "{{base_url}}/users/USER_ID_HERE", "host": ["{{base_url}}"], "path": ["users", "USER_ID_HERE"]}
          }
        },
        {
          "name": "Delete User (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/users/USER_ID_HERE", "host": ["{{base_url}}"], "path": ["users", "USER_ID_HERE"]}
          }
        }
      ]
    },
    {
      "name": "3. Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/products?page=1&limit=10", "host": ["{{base_url}}"], "path": ["products"], "query": [{"key":"page","value":"1"},{"key":"limit","value":"10"}]}
          }
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/products/search?keyword=laptop", "host": ["{{base_url}}"], "path": ["products", "search"], "query": [{"key":"keyword","value":"laptop"}]}
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/products/PRODUCT_ID_HERE", "host": ["{{base_url}}"], "path": ["products", "PRODUCT_ID_HERE"]}
          }
        },
        {
          "name": "Create Product (Admin)",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "name", "value": "New Laptop", "type": "text"},
                {"key": "shortDescription", "value": "Best laptop of 2026", "type": "text"},
                {"key": "description", "value": "A great laptop with massive specs", "type": "text"},
                {"key": "price", "value": "999.99", "type": "text"},
                {"key": "category", "value": "Electronics", "type": "text"},
                {"key": "brand", "value": "TechBrand", "type": "text"},
                {"key": "stock", "value": "50", "type": "text"},
                {"key": "images", "type": "file", "src": ""}
              ]
            },
            "url": {"raw": "{{base_url}}/products", "host": ["{{base_url}}"], "path": ["products"]}
          }
        },
        {
          "name": "Update Product (Admin)",
          "request": {
            "method": "PUT",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "price", "value": "899.99", "type": "text"}
              ]
            },
            "url": {"raw": "{{base_url}}/products/update/PRODUCT_ID_HERE", "host": ["{{base_url}}"], "path": ["products", "update", "PRODUCT_ID_HERE"]}
          }
        },
        {
          "name": "Delete Product (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/products/PRODUCT_ID_HERE", "host": ["{{base_url}}"], "path": ["products", "PRODUCT_ID_HERE"]}
          }
        },
        {
          "name": "Add Review",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Excellent product!\"\n}"
            },
            "url": {"raw": "{{base_url}}/products/PRODUCT_ID_HERE/reviews", "host": ["{{base_url}}"], "path": ["products", "PRODUCT_ID_HERE", "reviews"]}
          }
        },
        {
          "name": "Delete Review",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/products/PRODUCT_ID_HERE/reviews/REVIEW_ID_HERE", "host": ["{{base_url}}"], "path": ["products", "PRODUCT_ID_HERE", "reviews", "REVIEW_ID_HERE"]}
          }
        },
        {
          "name": "Get Product Reviews",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/products/PRODUCT_ID_HERE/reviews", "host": ["{{base_url}}"], "path": ["products", "PRODUCT_ID_HERE", "reviews"]}
          }
        }
      ]
    },
    {
      "name": "4. Cart",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/carts", "host": ["{{base_url}}"], "path": ["carts"]}
          }
        },
        {
          "name": "Add Item to Cart",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"PRODUCT_ID_HERE\",\n  \"quantity\": 2\n}"
            },
            "url": {"raw": "{{base_url}}/carts/items", "host": ["{{base_url}}"], "path": ["carts", "items"]}
          }
        },
        {
          "name": "Update Item Quantity",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"PRODUCT_ID_HERE\",\n  \"quantity\": 5\n}"
            },
            "url": {"raw": "{{base_url}}/carts/items", "host": ["{{base_url}}"], "path": ["carts", "items"]}
          }
        },
        {
          "name": "Remove Item from Cart",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/carts/items/PRODUCT_ID_HERE", "host": ["{{base_url}}"], "path": ["carts", "items", "PRODUCT_ID_HERE"]}
          }
        },
        {
          "name": "Apply Coupon",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"SAVE20\"\n}"
            },
            "url": {"raw": "{{base_url}}/carts/coupon", "host": ["{{base_url}}"], "path": ["carts", "coupon"]}
          }
        },
        {
          "name": "Remove Coupon",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/carts/coupon", "host": ["{{base_url}}"], "path": ["carts", "coupon"]}
          }
        },
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/carts/clear", "host": ["{{base_url}}"], "path": ["carts", "clear"]}
          }
        }
      ]
    },
    {
      "name": "5. Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shippingAddress\": {\n    \"fullName\": \"John Doe\",\n    \"phone\": \"1234567890\",\n    \"country\": \"USA\",\n    \"city\": \"New York\",\n    \"address\": \"123 Main St\",\n    \"postalCode\": \"10001\"\n  },\n  \"paymentMethod\": \"cash\"\n}"
            },
            "url": {"raw": "{{base_url}}/orders", "host": ["{{base_url}}"], "path": ["orders"]}
          }
        },
        {
          "name": "Create Payment Intent (Stripe)",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/orders/create-payment-intent", "host": ["{{base_url}}"], "path": ["orders", "create-payment-intent"]}
          }
        },
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/orders/my", "host": ["{{base_url}}"], "path": ["orders", "my"]}
          }
        },
        {
          "name": "Get My Specific Order",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/orders/my/ORDER_ID_HERE", "host": ["{{base_url}}"], "path": ["orders", "my", "ORDER_ID_HERE"]}
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/orders/my/ORDER_ID_HERE/cancel", "host": ["{{base_url}}"], "path": ["orders", "my", "ORDER_ID_HERE", "cancel"]}
          }
        }
      ]
    },
    {
      "name": "6. Wishlists",
      "item": [
        {
          "name": "Get My Wishlist",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/wishlists/my", "host": ["{{base_url}}"], "path": ["wishlists", "my"]}
          }
        },
        {
          "name": "Add Product to Wishlist",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/wishlists/add/PRODUCT_ID_HERE", "host": ["{{base_url}}"], "path": ["wishlists", "add", "PRODUCT_ID_HERE"]}
          }
        },
        {
          "name": "Remove Product from Wishlist",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/wishlists/remove/PRODUCT_ID_HERE", "host": ["{{base_url}}"], "path": ["wishlists", "remove", "PRODUCT_ID_HERE"]}
          }
        },
        {
          "name": "Clear Wishlist",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/wishlists/clear", "host": ["{{base_url}}"], "path": ["wishlists", "clear"]}
          }
        }
      ]
    },
    {
