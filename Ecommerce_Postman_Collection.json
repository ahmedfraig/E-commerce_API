{
  "info": {
    "name": "E-Commerce API",
    "description": "Complete Postman collection for the Ecommerce API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "1. Register (Send OTP)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"your_email@gmail.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {"raw": "{{base_url}}/auth/register/send-otp", "host": ["{{base_url}}"], "path": ["auth", "register", "send-otp"]}
          }
        },
        {
          "name": "2. Verify OTP",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"your_email@gmail.com\",\n  \"otp\": \"123456\"\n}"
            },
            "url": {"raw": "{{base_url}}/auth/verify-otp", "host": ["{{base_url}}"], "path": ["auth", "verify-otp"]}
          }
        },
        {
          "name": "3. Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if(jsonData.accessToken) {",
                  "    pm.collectionVariables.set(\"token\", jsonData.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"your_email@gmail.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {"raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"]}
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{base_url}}/products", "host": ["{{base_url}}"], "path": ["products"]}
          }
        },
        {
          "name": "Create Product (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "name", "value": "Test Product", "type": "text"},
                {"key": "description", "value": "A great product", "type": "text"},
                {"key": "price", "value": "99.99", "type": "text"},
                {"key": "stock", "value": "50", "type": "text"},
                {"key": "category", "value": "Electronics", "type": "text"}
              ]
            },
            "url": {"raw": "{{base_url}}/products", "host": ["{{base_url}}"], "path": ["products"]}
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get My Cart",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {"raw": "{{base_url}}/carts", "host": ["{{base_url}}"], "path": ["carts"]}
          }
        },
        {
          "name": "Add to Cart",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"replace_with_product_id\",\n  \"quantity\": 1\n}"
            },
            "url": {"raw": "{{base_url}}/carts/add", "host": ["{{base_url}}"], "path": ["carts", "add"]}
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Payment Intent",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {"raw": "{{base_url}}/orders/create-payment-intent", "host": ["{{base_url}}"], "path": ["orders", "create-payment-intent"]}
          }
        },
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shippingAddress\": {\n    \"street\": \"123 Main St\",\n    \"city\": \"New York\",\n    \"country\": \"USA\",\n    \"zipCode\": \"10001\"\n  },\n  \"paymentMethod\": \"card\"\n}"
            },
            "url": {"raw": "{{base_url}}/orders", "host": ["{{base_url}}"], "path": ["orders"]}
          }
        }
      ]
    }
  ]
}
